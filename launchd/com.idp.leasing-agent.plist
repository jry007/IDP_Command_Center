<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.idp.leasing-agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/yostenterprises/IDP_Command_Center/agents/leasing_followup_agent.py</string>
    </array>
    <!-- Runs every Monday at 8:30 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key><integer>1</integer>
        <key>Hour</key><integer>8</integer>
        <key>Minute</key><integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/yostenterprises/IDP_Command_Center/logs/leasing_agent.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/yostenterprises/IDP_Command_Center/logs/leasing_agent_error.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
