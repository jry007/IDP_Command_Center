<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.idp.portfolio-agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/yostenterprises/IDP_Command_Center/agents/portfolio_report_agent.py</string>
    </array>
    <!-- Runs Friday 6 PM and Monday 8 AM -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Weekday</key><integer>5</integer>
            <key>Hour</key><integer>18</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
        <dict>
            <key>Weekday</key><integer>1</integer>
            <key>Hour</key><integer>8</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
    </array>
    <key>StandardOutPath</key>
    <string>/Users/yostenterprises/IDP_Command_Center/logs/portfolio_agent.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/yostenterprises/IDP_Command_Center/logs/portfolio_agent_error.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
